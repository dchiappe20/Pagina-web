<%- include('partials/header') %>

<section class="hero">
  <div class="contenedor hero-int">
    <div class="hero-texto">
      <p class="eyebrow">Desarrollo de software y aplicaciones móviles</p>
      <h1>Software hecho a tu medida.</h1>
      <p class="hero-sub">
        Aplicaciones de escritorio, web y móviles construidas para tu proceso real.
        Integración con APIs, mantención y soporte continuo.
      </p>
      <div class="hero-acciones">
        <a class="btn" href="/productos">Ver productos</a>
        <a class="btn btn-secundario" href="/contacto">Hablemos</a>
      </div>
    </div>
    <div class="hero-figura" aria-hidden="true">
      <img src="/img/hero-software.svg" alt="">
    </div>
  </div>
  <div class="franja" aria-hidden="true"></div>
</section>

<section class="seccion">
  <div class="contenedor">
    <div class="seccion-cabeza">
      <h2>Nuestros productos</h2>
      <a class="enlace-mas" href="/productos">Ver todos los productos →</a>
    </div>
    <div class="grid grid-3">
      <% destacados.forEach(function (p) { %>
        <article class="tarjeta producto">
          <div class="producto-figura">
            <img src="/img/<%= p.icono %>.svg" alt="">
          </div>
          <p class="producto-cat"><%= p.etiqueta %></p>
          <h3 class="<%= p.placeholder ? 'placeholder-tag' : '' %>"><%= p.nombre %></h3>
          <p class="producto-desc"><%= p.desc %></p>
          <div class="producto-pie">
            <span class="precio"><%= p.precio %></span>
            <a class="btn btn-chico" href="/contacto">Cotizar</a>
          </div>
        </article>
      <% }); %>
    </div>
  </div>
</section>

<section class="seccion seccion-alterna">
  <div class="contenedor">
    <h2 class="centrado">Por qué trabajar con RendApps</h2>
    <div class="grid grid-3 ventajas">
      <div class="ventaja">
        <h3>Soporte y mantención</h3>
        <p>Corrección de errores y actualizaciones incluidas tras la entrega del software, según lo acordado.</p>
      </div>
      <div class="ventaja">
        <h3>Integración con tus sistemas</h3>
        <p>Conectamos con las APIs y plataformas que ya usas, como la API de Mercado Público.</p>
      </div>
      <div class="ventaja">
        <h3>Código a tu medida</h3>
        <p>Cada solución se construye para tu proceso específico, no un producto genérico forzado.</p>
      </div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="contenedor cta-int">
    <h2>¿Tienes un proceso que automatizar?</h2>
    <p>Cuéntanos qué necesitas y te armamos una propuesta con alcance, plazos y costos.</p>
    <a class="btn btn-claro" href="/contacto">Pedir propuesta</a>
  </div>
</section>

<%- include('partials/footer') %>
