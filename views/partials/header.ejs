<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= titulo %> · RendApps</title>
  <meta name="description" content="RendApps: desarrollamos aplicaciones móviles, software a medida, integraciones y soluciones web que optimizan procesos y generan valor real.">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css?v=5">
</head>
<body>
<a class="saltar" href="#contenido">Saltar al contenido</a>

<header class="cabecera" id="cabecera">
  <div class="contenedor cabecera-int">
    <a class="logo" href="/" aria-label="RendApps, inicio">
      <svg class="logo-icono" width="42" height="42" viewBox="0 0 40 40" aria-hidden="true">
        <defs>
          <linearGradient id="gradLogo" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#3B82F6"/>
            <stop offset="1" stop-color="#1E3A8A"/>
          </linearGradient>
        </defs>
        <rect x="5" y="5" width="30" height="30" rx="10" fill="url(#gradLogo)" transform="rotate(-8 20 20)"/>
        <text x="20" y="27" text-anchor="middle" font-family="'Space Grotesk','Arial',sans-serif" font-size="19" font-weight="700" fill="#fff">R</text>
        <circle class="logo-chispa" cx="33" cy="8" r="4" fill="#F97316"/>
        <circle cx="33" cy="8" r="1.6" fill="#fff"/>
      </svg>
      <span class="logo-texto">Rend<em>Apps</em></span>
    </a>

    <nav class="nav" id="nav-principal" aria-label="Principal">
      <ul class="nav-lista">
        <li><a href="/" class="nav-enlace <%= pagina === 'inicio' ? 'activo' : '' %>">Inicio</a></li>
        <li><a href="/servicios" class="nav-enlace <%= pagina === 'servicios' ? 'activo' : '' %>">Servicios</a></li>
        <li><a href="/proyectos" class="nav-enlace <%= pagina === 'proyectos' ? 'activo' : '' %>">Proyectos</a></li>
        <li><a href="/nosotros" class="nav-enlace <%= pagina === 'nosotros' ? 'activo' : '' %>">Nosotros</a></li>
        <li><a href="/soporte" class="nav-enlace <%= pagina === 'soporte' ? 'activo' : '' %>">Soporte</a></li>
    
        <li class="nav-cta-item"><a href="/contacto" class="btn btn-contorno btn-chico">Cotiza tu proyecto</a></li>
      </ul>
    </nav>

    <button class="menu-btn" type="button" aria-expanded="false" aria-controls="nav-principal" aria-label="Abrir menú">
      <%- include('icono', { n: 'menu', t: 24 }) %>
    </button>
  </div>
</header>

<main id="contenido">
