</main>

<footer class="pie">
  <div class="contenedor pie-int">
    <div class="pie-marca">
      <a class="logo" href="/" aria-label="RendApps, inicio">
        <svg class="logo-icono" width="38" height="38" viewBox="0 0 40 40" aria-hidden="true">
          <defs>
            <linearGradient id="gradLogoPie" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#3B82F6"/>
              <stop offset="1" stop-color="#1E3A8A"/>
            </linearGradient>
          </defs>
          <rect x="5" y="5" width="30" height="30" rx="10" fill="url(#gradLogoPie)" transform="rotate(-8 20 20)"/>
          <text x="20" y="27" text-anchor="middle" font-family="'Space Grotesk','Arial',sans-serif" font-size="19" font-weight="700" fill="#fff">R</text>
          <circle class="logo-chispa" cx="33" cy="8" r="4" fill="#F97316"/>
          <circle cx="33" cy="8" r="1.6" fill="#fff"/>
        </svg>
        <span class="logo-texto">Rend<em>Apps</em></span>
      </a>
      <p>Desarrollamos soluciones de software a medida que impulsan negocios y transforman ideas en productos digitales de alto impacto.</p>
    </div>

    <nav class="pie-col" aria-label="Navegación del sitio">
      <h3>Navegación</h3>
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/servicios">Servicios</a></li>
        <li><a href="/proyectos">Proyectos</a></li>
        <li><a href="/nosotros">Nosotros</a></li>
        <li><a href="/soporte">Soporte</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </nav>

    <nav class="pie-col" aria-label="Servicios">
      <h3>Servicios</h3>
      <ul>
        <% servicios.forEach(function (s) { %>
          <li><a href="/servicios#<%= s.id %>"><%= s.nombre %></a></li>
        <% }); %>
      </ul>
    </nav>

    <div class="pie-col pie-contacto">
      <h3>Contacto</h3>
      <ul>
        <li>
          <span class="pie-icono"><%- include('icono', { n: 'mail', t: 17 }) %></span>
          <a href="mailto:<%= empresa.email %>"><%= empresa.email %></a>
        </li>
        <li>
          <span class="pie-icono"><%- include('icono', { n: 'pin', t: 17 }) %></span>
          <span><%= empresa.ubicacion %></span>
        </li>
        <li>
          <span class="pie-icono"><%- include('icono', { n: 'reloj', t: 17 }) %></span>
          <span><%= empresa.horario %></span>
        </li>
      </ul>
    </div>
  </div>

  <div class="pie-legal">
    <div class="contenedor pie-legal-int">
      <p>© <%= new Date().getFullYear() %> RendApps · <%= empresa.razon %> · RUT <%= empresa.rut %></p>
      <p>Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<script src="/js/main.js?v=5"></script>
</body>
</html>
